# Environment Configuration for Pharmacogenomics Pipeline

# Database Configuration
POSTGRES_PASSWORD=pharmacogenomics_secure_pass
DATABASE_URL=postgresql+asyncpg://postgres:pharmacogenomics_secure_pass@localhost:5432/pharmacogenomics

# Redis Configuration
REDIS_PASSWORD=redis_secure_pass
REDIS_URL=redis://:redis_secure_pass@localhost:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://:redis_secure_pass@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secure_pass@localhost:6379/1

# Security
SECRET_KEY=your-very-secure-secret-key-here-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API Configuration
CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
DEBUG=false

# File Upload Configuration
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes
UPLOAD_PATH=/app/uploads
RESULTS_PATH=/app/results

# External API Keys
DRUGBANK_API_KEY=your-drugbank-api-key
ENSEMBL_VEP_API_KEY=optional-vep-api-key

# Monitoring
GRAFANA_PASSWORD=secure_grafana_password

# SSL Configuration (Production)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_VERSION=2.0.0

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# Backup Configuration
BACKUP_S3_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1