{
  "name": "pharmacogenomics-frontend",
  "version": "2.0.0",
  "description": "React frontend for Pharmacogenomics Analysis Pipeline",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
