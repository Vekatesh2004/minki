    "@tanstack/react-table": "^8.10.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.18.0",
    "react-hook-form": "^7.47.0",
    "react-dropzone": "^14.2.3",
    "axios": "^1.6.0",
    "recharts": "^2.8.0",
    "lucide-react": "^0.292.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0",
    "@hookform/resolvers": "^3.3.2",
    "zod": "^3.22.4",
    "react-hot-toast": "^2.4.1",
